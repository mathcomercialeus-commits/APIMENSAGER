PROJECT_NAME="AtendeCRM SaaS API"
ENVIRONMENT=development
DEBUG=true
API_V1_STR=/api/v1

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/atendecrm_saas
JWT_SECRET_KEY=troque_por_um_segredo_grande_e_unico
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
DATA_ENCRYPTION_SECRET=troque_por_uma_chave_de_criptografia_forte
AUTO_CREATE_TABLES=false
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

SEED_SUPERADMIN=true
SUPERADMIN_FULL_NAME="Administrador da Plataforma"
